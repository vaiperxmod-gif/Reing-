<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>REIGN SHOP - ULTIMATE PANEL</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;500;700&family=Orbitron:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-red: #ff0000;
            --status-green: #00ff40;
            --panel-bg: rgba(10, 10, 10, 0.98);
        }

        /* เอฟเฟกต์ขอบกะพริบ แดง-ดำ */
        @keyframes pulse-border {
            0% { border-color: var(--primary-red); box-shadow: 0 0 15px rgba(255, 0, 0, 0.5); }
            50% { border-color: #1a0000; box-shadow: 0 0 5px rgba(255, 0, 0, 0.1); }
            100% { border-color: var(--primary-red); box-shadow: 0 0 15px rgba(255, 0, 0, 0.5); }
        }

        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #000 radial-gradient(circle, #300 0%, #000 100%);
            font-family: 'Kanit', sans-serif;
            color: white;
            user-select: none;
            overflow: hidden;
        }

        /* --- LOGIN SECTION --- */
        #login-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95);
            display: flex; justify-content: center; align-items: center;
            z-index: 1000; transition: 0.6s;
        }

        .login-box {
            width: 320px;
            background: var(--panel-bg);
            border: 2px solid var(--primary-red);
            border-radius: 15px;
            padding: 35px;
            text-align: center;
            animation: pulse-border 3s infinite;
        }

        .login-box h2 { font-family: 'Orbitron', sans-serif; color: var(--primary-red); margin-bottom: 25px; letter-spacing: 2px; }
        .input-group { margin-bottom: 15px; text-align: left; }
        .input-group label { font-size: 11px; color: #888; display: block; margin-bottom: 5px; }
        .input-group input {
            width: 100%; background: #111; border: 1px solid #333; padding: 12px;
            color: white; border-radius: 6px; outline: none; box-sizing: border-box;
        }

        .btn-login {
            width: 100%; background: var(--primary-red); color: white; border: none;
            padding: 12px; border-radius: 6px; font-weight: bold; cursor: pointer;
            font-family: 'Kanit'; transition: 0.3s;
        }
        #error-msg { color: var(--primary-red); font-size: 12px; margin-top: 10px; display: none; }

        /* --- MAIN PANEL SECTION --- */
        .main-panel {
            width: 500px;
            background: var(--panel-bg);
            border: 2px solid var(--primary-red);
            border-radius: 12px;
            overflow: hidden;
            display: none;
            opacity: 0;
            transition: 0.8s;
            animation: pulse-border 5s infinite;
        }

        .panel-header {
            display: flex; justify-content: space-between; align-items: center;
            padding: 15px 20px;
            background: linear-gradient(180deg, rgba(255, 0, 0, 0.2) 0%, transparent 100%);
            border-bottom: 1px solid rgba(255, 0, 0, 0.3);
        }

        .header-title {
            font-family: 'Orbitron', sans-serif;
            display: flex; align-items: center; gap: 10px; font-size: 18px;
        }

        .panel-layout { display: flex; min-height: 380px; }

        /* Sidebar */
        .sidebar {
            width: 95px;
            border-right: 1px solid rgba(255,255,255,0.05);
            display: flex; flex-direction: column; align-items: center;
            padding-top: 20px; background: rgba(0, 0, 0, 0.4);
        }

        .nav-item {
            color: #444; margin-bottom: 20px; text-align: center;
            font-size: 10px; cursor: pointer; transition: 0.3s; width: 100%;
            padding: 10px 0;
        }
        .nav-item.active { color: var(--primary-red); border-left: 3px solid var(--primary-red); background: rgba(255,0,0,0.05); }
        .nav-item i { font-size: 22px; display: block; margin-bottom: 4px; }

        /* Content Area */
        .content { flex: 1; padding: 25px; display: none; }
        .content.active { display: block; }
        .content-title { 
            color: var(--primary-red); font-family: 'Orbitron'; 
            margin-bottom: 20px; font-size: 15px; letter-spacing: 1px;
            border-bottom: 1px solid rgba(255,0,0,0.1); padding-bottom: 5px;
        }

        .setting-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
        .setting-name { font-size: 14px; font-weight: 500; }
        .setting-status { font-size: 11px; color: #666; display: block; }
        .status-on { color: var(--status-green); font-weight: bold; }
        .status-off { color: var(--primary-red); font-weight: bold; }

        /* Game Buttons */
        .game-btn {
            width: 100%; background: #1a1a1a; border: 1px solid #333;
            padding: 15px; margin-bottom: 15px; border-radius: 8px;
            display: flex; align-items: center; gap: 15px; cursor: pointer;
            transition: 0.3s; color: white; font-weight: bold;
        }
        .game-btn:hover { border-color: var(--primary-red); background: #250000; transform: scale(1.02); }
        .game-btn i { font-size: 24px; color: var(--primary-red); }

        /* Sensitivity Slider */
        .sens-input { width: 100%; accent-color: var(--primary-red); cursor: pointer; margin-top: 10px; }

        /* Toggle Switch */
        .switch { position: relative; width: 40px; height: 18px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider-btn {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: #222; transition: .3s; border-radius: 20px; border: 1px solid #444;
        }
        .slider-btn:before {
            position: absolute; content: ""; height: 12px; width: 12px;
            left: 3px; bottom: 2px; background-color: white; transition: .3s; border-radius: 50%;
        }
        input:checked + .slider-btn { background-color: var(--primary-red); }
        input:checked + .slider-btn:before { transform: translateX(20px); }

        .info-card { background: rgba(255,255,255,0.03); padding: 15px; border-radius: 8px; border: 1px solid rgba(255,0,0,0.1); }
        .footer { text-align: center; padding: 12px; color: var(--primary-red); font-family: 'Orbitron'; font-size: 10px; border-top: 1px solid rgba(255,0,0,0.1); }
    </style>
</head>
<body>

    <div id="login-overlay">
        <div class="login-box">
            <h2>REIGN LOGIN</h2>
            <div class="input-group">
                <label>USERNAME</label>
                <input type="text" id="username" placeholder="Reignshop">
            </div>
            <div class="input-group">
                <label>PASSWORD</label>
                <input type="password" id="password" placeholder="Kingpanel">
            </div>
            <button class="btn-login" onclick="handleLogin()">เข้าสู่ระบบ</button>
            <p id="error-msg">ยูสเซอร์หรือรหัสผ่านไม่ถูกต้อง!</p>
        </div>
    </div>

    <div class="main-panel" id="main-menu">
        <div class="panel-header">
            <div class="header-title"><i class="fas fa-crown"></i> REIGN SHOP</div>
            <i class="fas fa-check-circle" style="color: var(--status-green); font-size: 18px;"></i>
        </div>

        <div class="panel-layout">
            <div class="sidebar">
                <div class="nav-item active" onclick="switchTab(event, 'aimbot-page')">
                    <i class="fas fa-crosshairs"></i>Aimbot
                </div>
                <div class="nav-item" onclick="switchTab(event, 'antiban-page')">
                    <i class="fas fa-shield-virus"></i>Anti-Ban
                </div>
                <div class="nav-item" onclick="switchTab(event, 'start-page')">
                    <i class="fas fa-gamepad"></i>Start Game
                </div>
                <div class="nav-item" onclick="switchTab(event, 'info-page')">
                    <i class="fas fa-circle-info"></i>Info
                </div>
            </div>

            <div id="aimbot-page" class="content active">
                <div class="content-title">AIMBOT SYSTEMS</div>
                <div class="setting-row">
                    <div class="info"><span>Enable Aimbot</span><span id="st1" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'st1')"><span class="slider-btn"></span></label>
                </div>
                <div class="setting-row">
                    <div class="info"><span>Enable SG Aimbot</span><span id="st2" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'st2')"><span class="slider-btn"></span></label>
                </div>
                <div class="setting-row">
                    <div class="info"><span>Ignore Knocked</span><span id="st3" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'st3')"><span class="slider-btn"></span></label>
                </div>
                <div style="margin-top: 20px;">
                    <div class="setting-row"><span>Sensitivity</span><span id="sens-val" style="color:red">50%</span></div>
                    <input type="range" min="0" max="100" value="50" class="sens-input" oninput="document.getElementById('sens-val').innerText = this.value + '%'">
                </div>
            </div>

            <div id="antiban-page" class="content">
                <div class="content-title">ANTI-BAN SYSTEMS</div>
                <div class="setting-row">
                    <div class="info"><span>ระบบกันแบน</span><span id="at1" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'at1')"><span class="slider-btn"></span></label>
                </div>
                <div class="setting-row">
                    <div class="info"><span>กันรีพอร์ต</span><span id="at2" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'at2')"><span class="slider-btn"></span></label>
                </div>
                <div class="setting-row">
                    <div class="info"><span>กันรหัสติดดำ</span><span id="at3" class="status-off">ปิดใช้งาน</span></div>
                    <label class="switch"><input type="checkbox" onchange="toggleLabel(this, 'at3')"><span class="slider-btn"></span></label>
                </div>
            </div>

            <div id="start-page" class="content">
                <div class="content-title">SELECT GAME TO START</div>
                <div class="game-btn" onclick="launchGame('com.dts.freefireth')">
                    <i class="fas fa-fire"></i> FREE FIRE (Original)
                </div>
                <div class="game-btn" onclick="launchGame('com.dts.freefiremax')">
                    <i class="fas fa-bolt"></i> FREE FIRE MAX
                </div>
                <p style="font-size: 11px; color: #666; text-align: center;">* หากกดแล้วไม่เด้ง โปรดเปิดเกมด้วยตนเอง</p>
            </div>

            <div id="info-page" class="content">
                <div class="content-title">USER INFORMATION</div>
                <div class="info-card">
                    <p style="margin: 10px 0;"><i class="fas fa-user" style="color:var(--primary-red)"></i> Username : REIGN SHOP</p>
                    <p style="margin: 10px 0;"><i class="fas fa-key" style="color:var(--primary-red)"></i> Password : Kingpanel</p>
                    <p style="margin: 10px 0;"><i class="fas fa-signal" style="color:var(--status-green)"></i> Status : <span style="color:var(--status-green)">ONLINE</span></p>
                    <hr style="border:0; border-top:1px solid rgba(255,255,255,0.1); margin:15px 0;">
                    <p style="font-size: 13px; color: #888; text-align: center;">โปรแกรมนี้เป็นเพียงพาแนลดูดหัวช่วยลาก</p>
                </div>
            </div>
        </div>
        <div class="footer">REIGN SHOP | VERSION 1.0</div>
    </div>

    <script>
        function handleLogin() {
            const u = document.getElementById('username').value;
            const p = document.getElementById('password').value;
            if (u === "Reignshop" && p === "Kingpanel") {
                document.getElementById('login-overlay').style.opacity = "0";
                setTimeout(() => {
                    document.getElementById('login-overlay').style.display = "none";
                    document.getElementById('main-menu').style.display = "block";
                    setTimeout(() => { document.getElementById('main-menu').style.opacity = "1"; }, 50);
                }, 600);
            } else { document.getElementById('error-msg').style.display = "block"; }
        }

        function switchTab(evt, name) {
            let contents = document.getElementsByClassName("content");
            for (let i = 0; i < contents.length; i++) { contents[i].classList.remove("active"); }
            let tabs = document.getElementsByClassName("nav-item");
            for (let i = 0; i < tabs.length; i++) { tabs[i].classList.remove("active"); }
            document.getElementById(name).classList.add("active");
            evt.currentTarget.classList.add("active");
        }

        function toggleLabel(checkbox, targetId) {
            const el = document.getElementById(targetId);
            if (checkbox.checked) { el.innerText = "เปิดใช้งาน"; el.className = "status-on"; }
            else { el.innerText = "ปิดใช้งาน"; el.className = "status-off"; }
        }

        function launchGame(package) {
            // ระบบ Intent สำหรับ Android (จะทำงานได้ดีเมื่อรันบน App ที่ครอบ WebView)
            window.location.href = "intent://#Intent;scheme=android-intent;package=" + package + ";end";
            // สำหรับ Browser ทั่วไปจะแจ้งเตือน
            setTimeout(() => { alert("กำลังพยายามเปิดเกม: " + package + "\nหากไม่เด้ง กรุณาเปิดเกมปกติ"); }, 500);
        }
    </script>
</body>
</html>
